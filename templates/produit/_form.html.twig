{{ form_start(form) }}
    <div class="form-grid">
        <div class="form-field form-field-full">
            {{ form_label(form.nom, 'Nom du produit') }}
            {{ form_widget(form.nom) }}
        </div>

        <div class="form-field form-field-full">
            {{ form_label(form.description, 'Description') }}
            {{ form_widget(form.description) }}
        </div>

        <div class="form-field">
            {{ form_label(form.prix, 'Prix (€)') }}
            {{ form_widget(form.prix) }}
        </div>

        <div class="form-field">
            {{ form_label(form.stock, 'Stock') }}
            {{ form_widget(form.stock) }}
        </div>

        <div class="form-field">
            {{ form_label(form.categorie, 'Catégorie') }}
            {{ form_widget(form.categorie) }}
        </div>

        <div class="form-field">
            {{ form_label(form.marque, 'Marque') }}
            {{ form_widget(form.marque) }}
        </div>

        <div class="form-field form-field-full">
            {{ form_label(form.image, "Nom du fichier image") }}
            {{ form_widget(form.image) }}
            <small class="form-hint">Exemple : iphone15.jpg (le fichier doit être dans public/images/)</small>
        </div>
    </div>

    <button class="btn-primary btn-submit">{{ button_label|default('Enregistrer') }}</button>
{{ form_end(form) }}
