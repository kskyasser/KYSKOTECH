                    <td>Smartphones</td>
                    <td>899 €</td>
                    <td>24</td>
                    <td><a href="#" class="action-link">Modifier</a> | <a href="#" class="action-link">Supprimer</a></td>
                </tr>
                <tr>
                    <td>MacBook Air</td>
                    <td>Ordinateurs</td>
                    <td>1199 €</td>
                    <td>12</td>
                    <td><a href="#" class="action-link">Modifier</a> | <a href="#" class="action-link">Supprimer</a></td>
                </tr>
                <tr>
                    <td>iPad Pro</td>
                    <td>Tablettes</td>
                    <td>999 €</td>
                    <td>8</td>
                    <td><a href="#" class="action-link">Modifier</a> | <a href="#" class="action-link">Supprimer</a></td>
                </tr>
                <tr>
                    <td>Casque audio</td>
                    <td>Accessoires</td>
                    <td>76 €</td>
                    <td>40</td>
                    <td><a href="#" class="action-link">Modifier</a> | <a href="#" class="action-link">Supprimer</a></td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

{% endblock %}