{% extends 'base.html.twig' %}

{% block title %}Administration - KYSKOTECH{% endblock %}

{% block body %}

<header class="header">
    <div class="header-content">
        <a href="{{ path('app_home') }}" class="logo">KYSKOTECH Admin</a>
        <nav class="header-nav">
            <a href="#">Déconnexion</a>
        </nav>
    </div>
</header>

<section class="section">
