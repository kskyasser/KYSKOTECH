{% extends 'base.html.twig' %}

{% block title %}KYSKOTECH - La tech au meilleur prix{% endblock %}

{% block body %}

<header class="header">
    <div class="header-content">
        <a href="{{ path('app_home') }}" class="logo">KYSKOTECH</a>
        <nav class="header-nav">
            <a href="#">Connexion</a>
            <a href="#">🛒 Panier</a>
        </nav>
    </div>
</header>
<section class="hero">
    <div class="hero-content">
        <h1>La tech au meilleur prix</h1>
        <p>Smartphones, ordinateurs, tablettes et accessoires au meilleur prix.</p>
        <a href="{{ path('app_catalogue') }}" class="btn-primary">Voir le catalogue</a>
    </div>
</section>
<section class="section">
    <div class="container">
        <h2 class="section-title">Nos catégories</h2>
        <div class="categories-grid">
            <div class="category-card">Smartphones</div>
            <div class="category-card">Ordinateurs</div>
            <div class="category-card">Tablettes</div>
            <div class="category-card">Accessoires</div>
        </div>
    </div>
</section>
<section class="section">
    <div class="container">
        <h2 class="section-title">Produits phares</h2>
        <div class="products-grid">
            {% for produit in produits %}
            <div class="product-card">
                <a href="{{ path('app_produit', {id: produit.id}) }}">
                    <img src="{{ asset('images/' ~ produit.image) }}" alt="{{ produit.nom }}" class="product-image">
                </a>
                <h3 class="product-name">
                    <a href="{{ path('app_produit', {id: produit.id}) }}">{{ produit.nom }}</a>
                </h3>
                <p class="product-price">{{ produit.prix }} €</p>
                <a href="{{ path('app_produit', {id: produit.id}) }}" class="btn-primary btn-block">Voir le produit</a>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
<footer class="footer">
    <div class="footer-content">
        <div class="footer-brand">
            <p class="footer-logo">KYSKOTECH</p>
            <p class="footer-slogan">La tech au meilleur prix</p>
        </div>
        <div class="footer-links">
            <a href="#">À propos</a>
            <a href="#">Contact</a>
            <a href="#">Mentions légales</a>
        </div>
    </div>
    <p class="footer-copyright">© 2026 KYSKOTECH - Tous droits réservés</p>
</footer>
{% endblock %}