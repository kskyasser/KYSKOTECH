{% extends 'base.html.twig' %}

{% block title %}{{ produit.nom }} - KYSKOTECH{% endblock %}

{% block body %}

<header class="header">
    <div class="header-content">
        <a href="{{ path('app_home') }}" class="logo">KYSKOTECH</a>
        <nav class="header-nav">
            <a href="{{ path('app_connexion') }}">Connexion</a>
            <a href="{{ path('app_panier') }}">🛒 Panier
    {% set panier = app.session.get('panier', {}) %}
    {% set nbArticles = 0 %}
    {% for quantite in panier %}{% set nbArticles = nbArticles + quantite %}{% endfor %}
    {% if nbArticles > 0 %}<span class="cart-badge">{{ nbArticles }}</span>{% endif %}
</a>
        </nav>
    </div>
</header>

<section class="section">
    <div class="container">

        <div class="product-detail">
            <img src="{{ asset('images/' ~ produit.image) }}" alt="{{ produit.nom }}" class="product-detail-image">
            <div class="product-detail-info">
                <h1>{{ produit.nom }}</h1>
                <p class="product-brand">{{ produit.marque.nom }}</p>
                <p class="product-detail-price">{{ produit.prix }} €</p>
                <p class="product-stock">✓ En stock ({{ produit.stock }} disponibles)</p>
                <p class="product-description">{{ produit.description }}</p>
                <a href="{{ path('app_panier_ajouter', {id: produit.id}) }}" class="btn-primary">🛒 Ajouter au panier</a>
            </div>
        </div>

        <div class="reviews">
            <h2 class="section-title">Avis clients</h2>
            {% for av in avis %}
            <div class="review-card">
                <p class="review-author">{{ av.auteur }}</p>
                <p class="review-stars">
                    {% for i in 1..5 %}{% if i <= av.note %}★{% else %}☆{% endif %}{% endfor %}
                </p>
                <p>{{ av.commentaire }}</p>
            </div>
            {% else %}
            <p>Aucun avis pour ce produit pour le moment.</p>
            {% endfor %}
        </div>

    </div>
</section>

{% endblock %}
