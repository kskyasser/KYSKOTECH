{% extends 'base.html.twig' %}

{% block title %}Catalogue - KYSKOTECH{% endblock %}

{% block body %}

<header class="header">
    <div class="header-content">
        <a href="{{ path('app_home') }}" class="logo">KYSKOTECH</a>
        <nav class="header-nav">
            <a href="#">Connexion</a>
            <a href="{{ path('app_panier') }}">🛒 Panier
    {% set panier = app.session.get('panier', {}) %}
    {% set nbArticles = 0 %}
    {% for quantite in panier %}{% set nbArticles = nbArticles + quantite %}{% endfor %}
    {% if nbArticles > 0 %}<span class="cart-badge">{{ nbArticles }}</span>{% endif %}
</a>
        </nav>
    </div>
</header>

<section class="section">
    <div class="container">
        <h1 class="section-title">Catalogue</h1>
        <div class="catalogue-layout">

            <aside class="filters">
                <h3 class="filters-title">Filtres</h3>

                <div class="filter-group">
                    <p class="filter-label">Catégorie</p>
                    {% for categorie in categories %}
                    <a href="{{ path('app_catalogue', {categorie: categorie.id}) }}">{{ categorie.nom }}</a>
                    {% endfor %}
                </div>

                <div class="filter-group">
                    <p class="filter-label">Marque</p>
                    {% for marque in marques %}
                    <a href="{{ path('app_catalogue', {marque: marque.id}) }}">{{ marque.nom }}</a>
                    {% endfor %}
                </div>

                <div class="filter-group">
                    <p class="filter-label">Prix</p>
                    <a href="{{ path('app_catalogue', {prix: 'moins500'}) }}">Moins de 500 €</a>
                    <a href="{{ path('app_catalogue', {prix: '500a1000'}) }}">500 € - 1000 €</a>
                    <a href="{{ path('app_catalogue', {prix: 'plus1000'}) }}">Plus de 1000 €</a>
                </div>

                <div class="filter-group">
                    <a href="{{ path('app_catalogue') }}" class="btn-primary btn-block">Réinitialiser</a>
                </div>
            </aside>

            <div class="products-grid-3">
                {% for produit in produits %}
                <div class="product-card">
                    <a href="{{ path('app_produit', {id: produit.id}) }}">
                        <img src="{{ asset('images/' ~ produit.image) }}" alt="{{ produit.nom }}" class="product-image">
                    </a>
                    <h3 class="product-name">
                        <a href="{{ path('app_produit', {id: produit.id}) }}">{{ produit.nom }}</a>
                    </h3>
                    <p class="product-price">{{ produit.prix }} €</p>
                    <a href="{{ path('app_produit', {id: produit.id}) }}" class="btn-primary btn-block">Voir le produit</a>
                    <a href="{{ path('app_panier_ajouter', {id: produit.id}) }}" class="btn-cart btn-block">🛒 Ajouter au panier</a>
                </div>
                {% else %}
                <p>Aucun produit ne correspond à ces critères.</p>
                {% endfor %}
            </div>

        </div>
    </div>
</section>

{% endblock %}