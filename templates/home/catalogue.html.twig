{% extends 'base.html.twig' %}

{% block title %}Catalogue - KYSKOTECH{% endblock %}

{% block body %}

<header class="header">
    <div class="header-content">
        <a href="{{ path('app_home') }}" class="logo">KYSKOTECH</a>
        <nav class="header-nav">
            <a href="#">Connexion</a>
            <a href="#">🛒 Panier</a>
        </nav>
    </div>
</header>

<section class="section">
    <div class="container">
        <h1 class="section-title">Catalogue</h1>
        <div class="catalogue-layout">

            <aside class="filters">
                <h3 class="filters-title">Filtres</h3>
                <div class="filter-group">
                    <p class="filter-label">Catégorie</p>
                    <a href="#">Smartphones</a>
                    <a href="#">Ordinateurs</a>
                    <a href="#">Tablettes</a>
                    <a href="#">Accessoires</a>
                </div>
                <div class="filter-group">
                    <p class="filter-label">Marque</p>
                    <a href="#">Apple</a>
                    <a href="#">Samsung</a>
                </div>
                <div class="filter-group">
                    <p class="filter-label">Prix</p>
                    <a href="#">Moins de 500 €</a>
                    <a href="#">500 € - 1000 €</a>
                    <a href="#">Plus de 1000 €</a>
                </div>
            </aside>

            <div class="products-grid-3">
                <div class="product-card">
                    <div class="product-image"></div>
                    <h3 class="product-name">iPhone 15</h3>
                    <p class="product-price">899 €</p>
                    <a href="#" class="btn-primary btn-block">Ajouter au panier</a>
                </div>
                <div class="product-card">
                    <div class="product-image"></div>
                    <h3 class="product-name">MacBook Air</h3>
                    <p class="product-price">1199 €</p>
                    <a href="#" class="btn-primary btn-block">Ajouter au panier</a>
                </div>
                <div class="product-card">
                    <div class="product-image"></div>
                    <h3 class="product-name">iPad Pro</h3>
                    <p class="product-price">999 €</p>
                    <a href="#" class="btn-primary btn-block">Ajouter au panier</a>
                </div>
                <div class="product-card">
                    <div class="product-image"></div>
                    <h3 class="product-name">Casque audio</h3>
                    <p class="product-price">76 €</p>
                    <a href="#" class="btn-primary btn-block">Ajouter au panier</a>
                </div>
                <div class="product-card">
                    <div class="product-image"></div>
                    <h3 class="product-name">Chargeur iPhone</h3>
                    <p class="product-price">45 €</p>
                    <a href="#" class="btn-primary btn-block">Ajouter au panier</a>
                </div>
                <div class="product-card">
                    <div class="product-image"></div>
                    <h3 class="product-name">Chargeur Samsung</h3>
                    <p class="product-price">40 €</p>
                    <a href="#" class="btn-primary btn-block">Ajouter au panier</a>
                </div>
            </div>

        </div>
    </div>
</section>

{% endblock %}