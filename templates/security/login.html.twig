{% extends 'base.html.twig' %}

{% block title %}Connexion - KYSKOTECH{% endblock %}

{% block body %}

<header class="header">
    <div class="header-content">
        <a href="{{ path('app_home') }}" class="logo">KYSKOTECH</a>
        <nav class="header-nav">
            <a href="{{ path('app_home') }}">Accueil</a>
            <a href="{{ path('app_catalogue') }}">Catalogue</a>
        </nav>
    </div>
</header>

<section class="section">
    <div class="login-card">
        <h1 class="login-title">Connexion</h1>

        <form method="post">
            {% if error %}
                <div class="login-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <div class="form-group">
                <label for="username">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" placeholder="exemple@email.com" autocomplete="email" required autofocus>
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" name="_password" id="password" placeholder="••••••••" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <button class="btn-primary btn-block" type="submit">Se connecter</button>
        </form>

        <p class="login-link"><a href="{{ path('app_home') }}">← Retour à l'accueil</a></p>
    </div>
</section>

{% endblock %}